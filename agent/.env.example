# DGX Spark agent config (copy to .env on the DGX Spark machine)
# The agent runs on DGX Spark and connects to Asterisk (typically Linux Docker in this setup).

# Host running Asterisk (agent connects here for ARI/WebSocket)
ASTERISK_IP=192.168.1.23
ARI_USER=ai_user
ARI_PASS=your_password

# Asterisk uses websocket_client.conf (uri = ws://DGX_IP:8787/media) — set DGX IP there, not in .env.

# vLLM on DGX Spark (localhost = same machine as agent)
VLLM_BASE_URL=http://localhost:8000/v1
LLM_MODEL=Qwen2-VL-7B-Instruct

# Opening line (optional). Default: Hello! How can I help you today?
# CALL_GREETING=Hello! How can I help you today?

# STT/TTS — tuned for DGX (use cpu/false only for non-GPU testing)
WHISPER_DEVICE=cuda
# Larger models improve phone transcription but cost CPU latency on aarch64 (try small or distil-small.en)
WHISPER_MODEL=base
PIPER_USE_CUDA=true
PIPER_VOICE=en_US-ryan-high

# VAD (Silero) — lower min_volume if the line is quiet/noisy (default 0.6)
# VAD_MIN_VOLUME=0.5
# VAD_STOP_SECS=0.35
# VAD_CONFIDENCE=0.7

# Seconds after each Piper TTSStopped before unmuting inbound audio (echo guard; default 0.45)
# BOT_STOP_AFTER_TTS_DEBOUNCE_S=0.45

# Hugging Face (optional) — speeds up downloads, higher rate limits. Required for gated models (Llama, Mistral, etc.)
# HF_TOKEN=hf_xxxxx
