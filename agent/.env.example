# DGX Spark agent config — copy to agent/.env on the DGX host (do not commit .env).
# Agent runs on DGX; Asterisk is usually Docker on another host. ARI hits Asterisk;
# Asterisk opens media WebSocket to this machine (see websocket_client.conf on Asterisk).

# Host running Asterisk (agent connects here for ARI)
ASTERISK_IP=192.168.1.23
ARI_USER=ai_user
ARI_PASS=your_password

# On Asterisk: websocket_client.conf uri = ws://<DGX_LAN_IP>:8787/media

# vLLM on DGX Spark (localhost = same machine as agent)
VLLM_BASE_URL=http://localhost:8000/v1
LLM_MODEL=Qwen2.5-7B-Instruct

# Opening line (optional). Default: IT support, how can I help you?
# CALL_GREETING=IT support, how can I help you?

# STT — whisper.cpp sidecar (GPU, CUDA on DGX Spark). Set WHISPER_API_URL to use it.
# When set, the agent uses OpenAISTTService pointed at the local whisper-server instead
# of the CTranslate2 local model (which has no aarch64 CUDA wheels and runs on CPU).
# docker-compose sets this automatically; override to "" to fall back to local CTranslate2.
# WHISPER_API_URL=http://whisper:8080/v1

# Local CTranslate2 fallback (used only when WHISPER_API_URL is unset).
# distil-small.en is ~3x faster than base with similar WER on English phone audio.
WHISPER_DEVICE=cuda
WHISPER_MODEL=distil-small.en
# WHISPER_MODEL=base
PIPER_USE_CUDA=true
PIPER_VOICE=en_US-ryan-high

# Filler phrase spoken when the LLM hasn't produced text within TOOL_CALL_FILLER_DELAY_S.
# Fires early (on LLM start + delay) so callers hear something before a tool call completes.
# Set to empty string to disable.
TOOL_CALL_FILLER=One moment please.
# Seconds to wait after LLM starts before playing the filler (default 0.5).
# Should be shorter than the time the LLM takes to stream its first text token.
# TOOL_CALL_FILLER_DELAY_S=0.5

# VAD (Silero) — lower min_volume if the line is quiet/noisy (default 0.6)
# VAD_MIN_VOLUME=0.5
# VAD_STOP_SECS=0.35
# VAD_CONFIDENCE=0.7

# Seconds after each Piper TTSStopped before unmuting inbound audio (echo guard; default 0.45)
# BOT_STOP_AFTER_TTS_DEBOUNCE_S=0.45

# Outbound μ-law: catch up when backlog exceeds this many ms (default 280). Reduces audio lost on hangup mid-TTS.
# ARI_ULAW_HIGH_WATER_MS=280

# Hugging Face (optional) — speeds up downloads, higher rate limits. Required for gated models (Llama, Mistral, etc.)
# HF_TOKEN=hf_xxxxx
